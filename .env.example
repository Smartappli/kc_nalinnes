# Example values for a server .env file.

# Either provide DB_DSN, or provide DB_HOST + DB_NAME.
# DB_DSN=mysql:dbname=kc_nalinnes;host=127.0.0.1;charset=utf8mb4
DB_HOST=127.0.0.1
DB_NAME=kc_nalinnes
DB_CHARSET=utf8mb4
DB_USER=
DB_PASS=

# Comma-separated manager accounts.
ADMIN_EMAILS=

# Optional feature flags and paths.
APP_DEBUG=0
TEMP_BYPASS_LOGIN=0
RESERVATION_EMAIL_TO=duchesnesakura@gmail.com
ALLOWED_PRECOMPLETED_PDFS=mutualia-ac-sport-fr.pdf
MEAL_RESERVATIONS_EXCEL_PATH=
AUTH_BOOTSTRAP_PASSWORD=
